# Nome do projeto - usado como prefixo nos containers
PROJECT_NAME=myapp

# Porta exposta pelo nginx (acesso externo)
NGINX_PORT=80

# MySQL - credenciais usadas pelo docker-compose para criar o banco
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=mydb
DB_USERNAME=myuser
DB_PASSWORD=mypassword

# Porta exposta do MySQL para acesso externo (ex: DBeaver, TablePlus)
DB_PORT_EXPOSE=3306

# Porta exposta do Redis para acesso externo
REDIS_PORT_EXPOSE=6379
